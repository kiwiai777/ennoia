{
  "name": "ennoia",
  "version": "0.2.0",
  "description": "User model layer across AI systems.",
  "type": "module",
  "bin": {
    "ennoia": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "build:mcp": "tsc && echo 'MCP server compiled successfully'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test \"src/**/__tests__/**/*.test.ts\" \"src/__tests__/**/*.test.ts\""
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/glob": "^8.1.0",
    "glob": "^13.0.6",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "stream-json": "^2.1.0"
  }
}
