{
  "name": "cortex",
  "version": "0.0.1",
  "private": true,
  "description": "User model layer across AI systems.",
  "type": "module",
  "bin": {
    "cortex": "./bin/cortex"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "build:mcp": "tsc && echo 'MCP server compiled successfully'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/__tests__/**/*.test.ts\" \"src/__tests__/**/*.test.ts\""
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/glob": "^8.1.0",
    "glob": "^13.0.6",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "stream-json": "^2.1.0"
  }
}
